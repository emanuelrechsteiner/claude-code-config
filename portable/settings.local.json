{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npm install:*)",
      "Bash(npm list:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(yarn:*)",
      "Bash(pnpm:*)",
      "Bash(bun:*)",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(tree:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(du:*)",
      "Bash(which:*)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(chmod:*)",
      "Bash(gh:*)",
      "Bash(docker ps:*)",
      "Bash(docker images:*)",
      "Bash(docker logs:*)",
      "Bash(docker inspect:*)",
      "Bash(docker exec:*)",
      "Bash(claude:*)",
      "Task(*)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(rm -rf /*:*)",
      "Bash(rm -rf ~/*:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(fdisk:*)",
      "Bash(> /dev/*:*)",
      "Bash(curl|wget|nc|netcat:*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/.aws/credentials)",
      "Read(**/.ssh/id_*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/secrets/**)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/secrets/**)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git checkout -- .:*)",
      "Bash(npm publish:*)",
      "Bash(npx prisma migrate deploy:*)",
      "Bash(docker run:*)",
      "Bash(docker build:*)",
      "Bash(docker compose up:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "echo '🚀 Claude Code session started - $(date)'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/guard-unsafe.sh \"$tool_name\" \"$tool_args\""
          },
          {
            "type": "command",
            "command": ".claude/hooks/git-state-check.sh \"$tool_input\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/file-protection.sh"
          },
          {
            "type": "command",
            "command": "echo '📝 File modification detected - remember to commit within 60 minutes'"
          },
          {
            "type": "command",
            "command": "if [ -d .torvaldsen ] && [ -f .torvaldsen/scope-manifest.json ]; then BRANCH=$(git branch --show-current 2>/dev/null); if echo \"$BRANCH\" | grep -q 'issue-'; then echo 'Torvaldsen: Scope guard active. Ensure changes are within issue scope.'; fi; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/auto-format.sh \"$file_path\""
          },
          {
            "type": "command",
            "command": ".claude/hooks/post-edit-validate.sh \"$file_path\""
          },
          {
            "type": "command",
            "command": "if [ -d .torvaldsen ]; then echo 'Torvaldsen: Remember to update PROJECT-STATUS.md if this completes an issue.'; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Check if there are uncommitted changes that should be committed. If significant work was done (code written, files modified) but not committed, respond with {\"ok\": false, \"reason\": \"Uncommitted changes detected. Please commit before stopping.\"}. Otherwise respond with {\"ok\": true}."
          },
          {
            "type": "prompt",
            "prompt": "Check if the project has a .torvaldsen/ directory. If yes, check if .torvaldsen/agent-log.md was updated this session. If the agent worked on code or issues but did NOT append to the agent log, respond with {\"ok\": false, \"reason\": \"This is a Torvaldsen project. Please run /handoff before ending your session to preserve context for the next agent.\"}. If the log was updated or no significant work was done, respond with {\"ok\": true}."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "echo '✅ Sub-agent completed task'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": ".claude/hooks/statusline-command.sh"
  },
  "agents": {
    "auto-activate": true,
    "coordination-required": true,
    "reporting-interval": 30
  },
  "model": "sonnet",
  "env": {
    "MAX_THINKING_TOKENS": "10000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "90"
  }
}
